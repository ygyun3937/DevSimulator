<Window x:Class="SimulatorProject.Help.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="DevSimulator 도움말" Height="800" Width="1100"
        Background="#1a1a2e" WindowStartupLocation="CenterOwner">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#16162b" BorderBrush="#2a2a4a"
                BorderThickness="0,0,0,1" Padding="16,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="&#x1F4D6; 도움말" FontSize="16"
                           Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnSetupGuide" Content="&#x1F9ED; 사용 가이드 (비개발자용)"
                            Click="BtnSetupGuide_Click" Padding="12,6" Margin="0,0,6,0"
                            Background="#5B21B6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="BtnProtocolGuide" Content="&#x1F50C; 프로토콜 명세 (개발자용)"
                            Click="BtnProtocolGuide_Click" Padding="12,6" Margin="0,0,6,0"
                            Background="#374151" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="BtnOpenExternal" Content="&#x1F310; 브라우저에서 열기"
                            Click="BtnOpenExternal_Click" Padding="12,6"
                            Background="Transparent" Foreground="#a5b4fc" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
                <TextBlock/>
            </DockPanel>
        </Border>
        <wv2:WebView2 x:Name="WebViewer"/>
    </DockPanel>
</Window>
