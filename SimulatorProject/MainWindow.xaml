<Window x:Class="SimulatorProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:nodes="clr-namespace:SimulatorProject.Nodes"
        xmlns:vm="clr-namespace:SimulatorProject.ViewModels"
        Title="장치 인터페이스 시뮬레이터" Height="800" Width="1400"
        Background="#1a1a2e" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Dark TextBox style -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2d2d44"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#3f3f5e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <!-- Toolbox button style -->
        <Style x:Key="ToolboxButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Header button style -->
        <Style x:Key="HeaderButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Delete button style -->
        <Style x:Key="DeleteButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#aaaaaa"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#ff6666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Block inline label -->
        <Style x:Key="BlockLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#ccccdd"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- Block inline textbox -->
        <Style x:Key="BlockTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#3f3f5e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>

        <!-- SendSignal template -->
        <DataTemplate x:Key="SendSignalTemplate">
            <StackPanel Margin="12,6,12,10">
                <DockPanel>
                    <TextBlock Text="메시지:" Style="{StaticResource BlockLabel}"/>
                    <TextBox Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource BlockTextBox}"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>

        <!-- WaitSignal template -->
        <DataTemplate x:Key="WaitSignalTemplate">
            <StackPanel Margin="12,6,12,10">
                <DockPanel Margin="0,0,0,6">
                    <TextBlock Text="예상 신호:" Style="{StaticResource BlockLabel}"/>
                    <TextBox Text="{Binding ExpectedSignal, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource BlockTextBox}"/>
                </DockPanel>
                <DockPanel>
                    <TextBlock Text="제한시간(ms):" Style="{StaticResource BlockLabel}"/>
                    <TextBox Text="{Binding TimeoutMs, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource BlockTextBox}" Width="100" HorizontalAlignment="Left"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>

        <!-- Wait (시간 지연) template -->
        <DataTemplate x:Key="WaitTemplate">
            <StackPanel Margin="12,6,12,10">
                <DockPanel>
                    <TextBlock Text="대기(ms):" Style="{StaticResource BlockLabel}"/>
                    <TextBox Text="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource BlockTextBox}" Width="100" HorizontalAlignment="Left"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>

        <!-- DeviceStateChange template -->
        <DataTemplate x:Key="DeviceStateChangeTemplate">
            <StackPanel Margin="12,6,12,10">
                <DockPanel>
                    <TextBlock Text="변수명:" Style="{StaticResource BlockLabel}"/>
                    <TextBox Text="{Binding VariableName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource BlockTextBox}" Width="100"/>
                    <TextBlock Text="  =  " Foreground="#888" FontSize="14" VerticalAlignment="Center"
                               Margin="4,0"/>
                    <TextBox Text="{Binding VariableValue, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource BlockTextBox}"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>

        <!-- SetValue (SLMP) template -->
        <DataTemplate x:Key="SetValueTemplate">
            <StackPanel Margin="12,6,12,10">
                <DockPanel>
                    <TextBlock Text="디바이스:" Style="{StaticResource BlockLabel}"/>
                    <TextBox Text="{Binding DeviceKey, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource BlockTextBox}" Width="80"/>
                    <TextBlock Text="  =  " Foreground="#888" FontSize="14" VerticalAlignment="Center"
                               Margin="4,0"/>
                    <TextBox Text="{Binding DeviceValue, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource BlockTextBox}" Width="80" HorizontalAlignment="Left"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>

        <!-- WaitCondition (SLMP) template -->
        <DataTemplate x:Key="WaitConditionTemplate">
            <StackPanel Margin="12,6,12,10">
                <DockPanel Margin="0,0,0,6">
                    <TextBlock Text="디바이스:" Style="{StaticResource BlockLabel}"/>
                    <TextBox Text="{Binding WcDeviceKey, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource BlockTextBox}" Width="80"/>
                    <TextBlock Text=" == " Foreground="#888" FontSize="13" VerticalAlignment="Center"
                               Margin="4,0"/>
                    <TextBox Text="{Binding WcCompareValue, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource BlockTextBox}" Width="60" HorizontalAlignment="Left"/>
                </DockPanel>
                <DockPanel>
                    <TextBlock Text="폴링(ms):" Style="{StaticResource BlockLabel}"/>
                    <TextBox Text="{Binding WcPollingMs, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource BlockTextBox}" Width="60"/>
                    <TextBlock Text="타임아웃(ms):" Style="{StaticResource BlockLabel}" Margin="12,0,8,0"/>
                    <TextBox Text="{Binding WcTimeoutMs, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource BlockTextBox}" Width="80" HorizontalAlignment="Left"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>

        <!-- Loop template -->
        <DataTemplate x:Key="LoopTemplate">
            <StackPanel Margin="12,6,12,10">
                <DockPanel Margin="0,0,0,6">
                    <TextBlock Text="돌아갈 단계:" Style="{StaticResource BlockLabel}"/>
                    <TextBox Text="{Binding LoopTargetStep, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource BlockTextBox}" Width="50" HorizontalAlignment="Left"/>
                </DockPanel>
                <DockPanel>
                    <TextBlock Text="반복 횟수:" Style="{StaticResource BlockLabel}"/>
                    <TextBox Text="{Binding LoopMaxCount, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource BlockTextBox}" Width="50"/>
                    <TextBlock Text="(0 = 무한)" Foreground="#555" FontSize="10" VerticalAlignment="Center"
                               Margin="8,0,0,0"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>

        <!-- ConditionBranch template -->
        <DataTemplate x:Key="ConditionBranchTemplate">
            <StackPanel Margin="12,6,12,10">
                <DockPanel Margin="0,0,0,6">
                    <TextBlock Text="변수명:" Style="{StaticResource BlockLabel}"/>
                    <TextBox Text="{Binding CondVarName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource BlockTextBox}" Width="100"/>
                    <ComboBox SelectedItem="{Binding CondOperator}" Margin="8,0"
                              Background="#FFFFFF" Foreground="#000000" FontSize="13"
                              FontWeight="SemiBold" BorderBrush="#3f3f5e" Width="60">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="#000000"/>
                                <Setter Property="Background" Value="#FFFFFF"/>
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Style.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter Property="Background" Value="#5B21B6"/>
                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBoxItem Content="==" IsSelected="True"/>
                        <ComboBoxItem Content="!="/>
                        <ComboBoxItem Content="&gt;"/>
                        <ComboBoxItem Content="&lt;"/>
                        <ComboBoxItem Content="&gt;="/>
                        <ComboBoxItem Content="&lt;="/>
                    </ComboBox>
                    <TextBox Text="{Binding CondCompareValue, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource BlockTextBox}"/>
                </DockPanel>
                <DockPanel>
                    <TextBlock Text="OK:" Foreground="#4ADE80" FontSize="12" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="다음 단계로 진행" Foreground="#777" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <TextBlock Text="NG:" Foreground="#F87171" FontSize="12" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="단계" Foreground="#999" FontSize="12" VerticalAlignment="Center"
                               Margin="0,0,4,0"/>
                    <TextBox Text="{Binding NgTargetStep, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource BlockTextBox}" Width="50" HorizontalAlignment="Left"/>
                    <TextBlock Text="(0=종료)" Foreground="#555" FontSize="10" VerticalAlignment="Center"
                               Margin="6,0,0,0"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- === Title Bar === -->
        <Border Grid.Row="0" Background="#16162b" BorderBrush="#2a2a4a" BorderThickness="0,0,0,1">
            <DockPanel Margin="16,0">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x2699;" FontSize="20" Foreground="#7C7CFF" Margin="0,0,10,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="장치 인터페이스 시뮬레이터" FontSize="16" Foreground="White"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="&#x2753; 도움말" Background="#0E639C"
                            Style="{StaticResource HeaderButton}" Margin="0,0,12,0"
                            Click="OpenHelp_Click"/>
                    <Button Content="&#x25B6; 전체 시작" Background="#5B21B6"
                            Style="{StaticResource HeaderButton}" Margin="0,0,6,0"
                            Command="{Binding StartAllCommand}"/>
                    <Button Content="&#x23F9; 전체 정지" Background="#991B1B"
                            Style="{StaticResource HeaderButton}" Margin="0,0,6,0"
                            Command="{Binding StopAllCommand}"/>
                    <Button Content="&#x21BB; 전체 초기화" Background="#374151"
                            Style="{StaticResource HeaderButton}"
                            Command="{Binding ResetAllCommand}"/>
                </StackPanel>
                <StackPanel/>
            </DockPanel>
        </Border>

        <!-- === Group Tab Bar === -->
        <Border Grid.Row="1" Background="#12122a" BorderBrush="#2a2a4a" BorderThickness="0,0,0,1">
            <DockPanel Margin="8,4">
                <!-- 그룹 추가 버튼 -->
                <Button DockPanel.Dock="Left" Content="+ 그룹 추가" Background="#374151"
                        Foreground="White" FontSize="11" Padding="10,5" Cursor="Hand"
                        BorderThickness="0" Margin="0,0,8,0"
                        Command="{Binding AddGroupCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- 그룹 탭 목록 -->
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="TabBorder" CornerRadius="4" Padding="10,5" Margin="2,0"
                                    Cursor="Hand" Background="#1e1e3a"
                                    MouseLeftButtonDown="GroupTab_Click" Tag="{Binding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding StatusIndicator}" FontSize="10" Margin="0,0,6,0"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#555"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                        <Setter Property="Foreground" Value="#4ADE80"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Text="{Binding GroupName, UpdateSourceTrigger=LostFocus}"
                                             Background="Transparent" Foreground="White" FontSize="12"
                                             BorderThickness="0" Padding="0" CaretBrush="White"
                                             MinWidth="40" MaxWidth="120"/>
                                    <TextBlock Text="{Binding Port, StringFormat=':{0}'}"
                                               Foreground="#666" FontSize="10" VerticalAlignment="Center"
                                               Margin="4,0,0,0"/>
                                    <Button Content="&#x2716;" FontSize="9" Foreground="#555"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Margin="6,0,0,0" Padding="2" VerticalAlignment="Center"
                                            Click="RemoveGroup_Click" Tag="{Binding}"/>
                                </StackPanel>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="True">
                                    <Setter TargetName="TabBorder" Property="Background" Value="#2a2a5a"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- === Main Content (선택된 그룹) === -->
        <Grid Grid.Row="2" DataContext="{Binding SelectedGroup}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Block Toolbox -->
            <Border Grid.Column="0" Background="#16162b" BorderBrush="#2a2a4a" BorderThickness="0,0,1,0">
                <StackPanel Margin="12,16">
                    <TextBlock Text="블록 도구상자" FontSize="14" Foreground="White" FontWeight="Bold"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="원하는 블록을 우측 시나리오 창으로 드래그 하세요."
                               Foreground="#777799" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <Button Tag="SendSignal" Background="#4F46E5" Style="{StaticResource ToolboxButton}"
                            PreviewMouseLeftButtonDown="PaletteButton_MouseDown">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x25B6;" Margin="0,0,8,0"/>
                            <TextBlock Text="신호 전송"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="WaitSignal" Background="#7C3AED" Style="{StaticResource ToolboxButton}"
                            PreviewMouseLeftButtonDown="PaletteButton_MouseDown">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2B07;" Margin="0,0,8,0"/>
                            <TextBlock Text="신호 수신 대기"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="Wait" Background="#EA580C" Style="{StaticResource ToolboxButton}"
                            PreviewMouseLeftButtonDown="PaletteButton_MouseDown">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x23F1;" Margin="0,0,8,0"/>
                            <TextBlock Text="시간 지연"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="DeviceStateChange" Background="#16A34A" Style="{StaticResource ToolboxButton}"
                            PreviewMouseLeftButtonDown="PaletteButton_MouseDown">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2699;" Margin="0,0,8,0"/>
                            <TextBlock Text="장치 상태 변경"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="ConditionBranch" Background="#DC2626" Style="{StaticResource ToolboxButton}"
                            PreviewMouseLeftButtonDown="PaletteButton_MouseDown">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2753;" Margin="0,0,8,0"/>
                            <TextBlock Text="조건 분기"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="Loop" Background="#D946EF" Style="{StaticResource ToolboxButton}"
                            PreviewMouseLeftButtonDown="PaletteButton_MouseDown">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x21BB;" Margin="0,0,8,0"/>
                            <TextBlock Text="반복"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="SLMP 디바이스" FontSize="11" Foreground="#555577"
                               Margin="0,16,0,4" FontWeight="Bold"/>

                    <Button Tag="SetValue" Background="#CA5010" Style="{StaticResource ToolboxButton}"
                            PreviewMouseLeftButtonDown="PaletteButton_MouseDown">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x270F;" Margin="0,0,8,0"/>
                            <TextBlock Text="디바이스 쓰기"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="WaitCondition" Background="#0E639C" Style="{StaticResource ToolboxButton}"
                            PreviewMouseLeftButtonDown="PaletteButton_MouseDown">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x23F3;" Margin="0,0,8,0"/>
                            <TextBlock Text="디바이스 대기"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Center: Scenario Editor -->
            <Border Grid.Column="1" Background="#1a1a2e">
                <DockPanel>
                    <!-- Header -->
                    <Border DockPanel.Dock="Top" Background="#16162b" BorderBrush="#2a2a4a"
                            BorderThickness="0,0,0,1" Padding="16,10">
                        <DockPanel>
                            <!-- 좌측: 제목 + 단계 수 -->
                            <TextBlock Text="{Binding GroupName, StringFormat='{}{0} — 시나리오 편집기'}"
                                       FontSize="14" Foreground="White" FontWeight="Bold"
                                       VerticalAlignment="Center"/>

                            <!-- 우측: 그룹 제어 -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ScenarioEditor.TotalSteps, StringFormat='{}{0}단계'}"
                                           Foreground="#888" FontSize="11" VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>

                                <!-- IP:Port -->
                                <TextBlock Text="IP:" Foreground="#666" FontSize="11" VerticalAlignment="Center"
                                           Margin="0,0,3,0"/>
                                <TextBox Text="{Binding Ip, UpdateSourceTrigger=PropertyChanged}"
                                         Width="90" FontSize="11" Padding="3,2"
                                         Background="#1a1a2e" Foreground="White" BorderBrush="#3f3f5e"
                                         CaretBrush="White" VerticalContentAlignment="Center"/>
                                <TextBlock Text=":" Foreground="#666" FontSize="11" VerticalAlignment="Center"
                                           Margin="2,0"/>
                                <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                         Width="45" FontSize="11" Padding="3,2"
                                         Background="#1a1a2e" Foreground="White" BorderBrush="#3f3f5e"
                                         CaretBrush="White" VerticalContentAlignment="Center"/>

                                <TextBlock Text="{Binding ConnectedClients, StringFormat='({0})'}"
                                           Foreground="#555" FontSize="10" VerticalAlignment="Center"
                                           Margin="4,0,8,0"/>

                                <!-- 그룹 제어 버튼 -->
                                <Button Content="&#x25B6;" Background="#5B21B6" Foreground="White"
                                        FontSize="11" Padding="8,4" Cursor="Hand" BorderThickness="0"
                                        Command="{Binding StartCommand}" ToolTip="시작">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="&#x23F9;" Background="#991B1B" Foreground="White"
                                        FontSize="11" Padding="8,4" Cursor="Hand" BorderThickness="0"
                                        Margin="3,0" Command="{Binding StopCommand}" ToolTip="정지">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="&#x1F4BE;" Background="#1E40AF" Foreground="White"
                                        FontSize="11" Padding="8,4" Cursor="Hand" BorderThickness="0"
                                        Margin="0,0,3,0" Command="{Binding SaveScenarioCommand}" ToolTip="저장">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="&#x1F4C2;" Background="#1E40AF" Foreground="White"
                                        FontSize="11" Padding="8,4" Cursor="Hand" BorderThickness="0"
                                        Command="{Binding LoadScenarioCommand}" ToolTip="불러오기">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Block list (drop target) -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  AllowDrop="True" Drop="BlockList_Drop" DragOver="BlockList_DragOver"
                                  x:Name="BlockListScroller">
                        <ItemsControl ItemsSource="{Binding ScenarioEditor.Blocks}" Margin="40,20,40,40"
                                      x:Name="BlockListControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:BlockViewModel}">
                                    <StackPanel>
                                        <!-- Block card -->
                                        <Border CornerRadius="8" Margin="0,4" x:Name="BlockBorder">
                                            <Border.Background>
                                                <SolidColorBrush Color="#2a2a44"/>
                                            </Border.Background>
                                            <Border.BorderBrush>
                                                <SolidColorBrush x:Name="BorderBrushColor" Color="#3a3a5a"/>
                                            </Border.BorderBrush>
                                            <Border.BorderThickness>
                                                <Thickness>2</Thickness>
                                            </Border.BorderThickness>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Title bar -->
                                                <Border Grid.Row="0" CornerRadius="6,6,0,0" Padding="12,8"
                                                        Background="{Binding AccentBrush}">
                                                    <DockPanel>
                                                        <!-- Step number badge -->
                                                        <Border DockPanel.Dock="Left" Background="#00000044"
                                                                CornerRadius="12" Width="24" Height="24"
                                                                Margin="0,0,10,0">
                                                            <TextBlock Text="{Binding StepNumber}"
                                                                       Foreground="White" FontSize="12"
                                                                       FontWeight="Bold"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>

                                                        <!-- Block action buttons -->
                                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                            <Button Style="{StaticResource DeleteButton}"
                                                                    Content="&#x25B2;" ToolTip="위로 이동"
                                                                    Click="MoveBlockUp_Click" Tag="{Binding}"/>
                                                            <Button Style="{StaticResource DeleteButton}"
                                                                    Content="&#x25BC;" ToolTip="아래로 이동"
                                                                    Click="MoveBlockDown_Click" Tag="{Binding}"/>
                                                            <Button Style="{StaticResource DeleteButton}"
                                                                    Content="&#x1F5D1;" ToolTip="삭제"
                                                                    Click="DeleteBlock_Click" Tag="{Binding}"/>
                                                        </StackPanel>

                                                        <!-- Icon + Title -->
                                                        <StackPanel Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding BlockIcon}"
                                                                       Foreground="White" FontSize="14"
                                                                       Margin="0,0,8,0"/>
                                                            <TextBlock Text="{Binding BlockTitle}"
                                                                       Foreground="White" FontSize="14"
                                                                       FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </DockPanel>
                                                </Border>

                                                <!-- Properties area -->
                                                <ContentControl Grid.Row="1"
                                                                Content="{Binding}"
                                                                x:Name="PropsContent"/>
                                            </Grid>
                                        </Border>

                                        <!-- 삽입 가능한 화살표 영역 -->
                                        <Border AllowDrop="True" Background="Transparent"
                                                Drop="InsertPoint_Drop" DragOver="InsertPoint_DragOver"
                                                Tag="{Binding}" MinHeight="24" Cursor="Hand"
                                                x:Name="InsertZone">
                                            <TextBlock Text="&#x2193;" Foreground="#555577" FontSize="20"
                                                       HorizontalAlignment="Center" Margin="0,2"/>
                                        </Border>
                                    </StackPanel>

                                    <DataTemplate.Triggers>
                                        <!-- SendSignalNode -->
                                        <DataTrigger Binding="{Binding NodeTypeName}" Value="SendSignalNode">
                                            <Setter TargetName="PropsContent" Property="ContentTemplate"
                                                    Value="{StaticResource SendSignalTemplate}"/>
                                        </DataTrigger>
                                        <!-- WaitSignalNode -->
                                        <DataTrigger Binding="{Binding NodeTypeName}" Value="WaitSignalNode">
                                            <Setter TargetName="PropsContent" Property="ContentTemplate"
                                                    Value="{StaticResource WaitSignalTemplate}"/>
                                        </DataTrigger>
                                        <!-- WaitNode -->
                                        <DataTrigger Binding="{Binding NodeTypeName}" Value="WaitNode">
                                            <Setter TargetName="PropsContent" Property="ContentTemplate"
                                                    Value="{StaticResource WaitTemplate}"/>
                                        </DataTrigger>
                                        <!-- DeviceStateChangeNode -->
                                        <DataTrigger Binding="{Binding NodeTypeName}" Value="DeviceStateChangeNode">
                                            <Setter TargetName="PropsContent" Property="ContentTemplate"
                                                    Value="{StaticResource DeviceStateChangeTemplate}"/>
                                        </DataTrigger>
                                        <!-- SetValueNode (SLMP) -->
                                        <DataTrigger Binding="{Binding NodeTypeName}" Value="SetValueNode">
                                            <Setter TargetName="PropsContent" Property="ContentTemplate"
                                                    Value="{StaticResource SetValueTemplate}"/>
                                        </DataTrigger>
                                        <!-- WaitConditionNode (SLMP) -->
                                        <DataTrigger Binding="{Binding NodeTypeName}" Value="WaitConditionNode">
                                            <Setter TargetName="PropsContent" Property="ContentTemplate"
                                                    Value="{StaticResource WaitConditionTemplate}"/>
                                        </DataTrigger>
                                        <!-- ConditionBranchNode -->
                                        <DataTrigger Binding="{Binding NodeTypeName}" Value="ConditionBranchNode">
                                            <Setter TargetName="PropsContent" Property="ContentTemplate"
                                                    Value="{StaticResource ConditionBranchTemplate}"/>
                                        </DataTrigger>
                                        <!-- LoopNode -->
                                        <DataTrigger Binding="{Binding NodeTypeName}" Value="LoopNode">
                                            <Setter TargetName="PropsContent" Property="ContentTemplate"
                                                    Value="{StaticResource LoopTemplate}"/>
                                        </DataTrigger>
                                        <!-- Executing highlight -->
                                        <DataTrigger Binding="{Binding IsExecuting}" Value="True">
                                            <Setter TargetName="BlockBorder" Property="BorderBrush"
                                                    Value="#FFD700"/>
                                            <Setter TargetName="BlockBorder" Property="BorderThickness"
                                                    Value="3"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Right Panel -->
            <Border Grid.Column="2" Background="#16162b" BorderBrush="#2a2a4a" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Virtual Device State -->
                    <DockPanel Grid.Row="0" Margin="16,16,16,8">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#x26A1;" FontSize="16" Foreground="#FFD700" Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="가상 장치 상태" FontSize="14" Foreground="White"
                                       FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Background="#1a1a2e" CornerRadius="6" BorderBrush="#2a2a4a"
                                BorderThickness="1">
                            <ItemsControl ItemsSource="{Binding DeviceState.Entries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#2a2a4a" BorderThickness="0,0,0,1"
                                                Padding="12,8">
                                            <DockPanel>
                                                <TextBlock Text="{Binding Key}" Foreground="#9cdcfe"
                                                           FontSize="13" VerticalAlignment="Center"/>
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding Value}"
                                                           Foreground="#4EC9B0" FontSize="13"
                                                           FontWeight="Bold" HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </DockPanel>

                    <!-- Periodic Tasks -->
                    <Border Grid.Row="1" BorderBrush="#2a2a4a" BorderThickness="0,1,0,0"
                            Padding="16,12">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8">
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                    <TextBlock Text="&#x21BB;" FontSize="14" Foreground="#D946EF"
                                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="주기 태스크" FontSize="14" Foreground="White"
                                               FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button DockPanel.Dock="Right" Content="+ 추가" Background="#D946EF"
                                        Foreground="White" FontSize="11" Padding="8,3" Cursor="Hand"
                                        BorderThickness="0" HorizontalAlignment="Right"
                                        Command="{Binding PeriodicTasks.AddTaskCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DockPanel>

                            <ItemsControl ItemsSource="{Binding PeriodicTasks.Tasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1a1a2e" CornerRadius="4" Padding="8,6"
                                                Margin="0,0,0,4" BorderBrush="#2a2a4a" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <DockPanel Margin="0,0,0,4">
                                                        <TextBlock Text="디바이스:" Foreground="#888" FontSize="11"
                                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                        <TextBox Text="{Binding DeviceKey, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource BlockTextBox}" Width="60"
                                                                 FontSize="11" Padding="4,2"/>
                                                        <TextBlock Text="간격(ms):" Foreground="#888" FontSize="11"
                                                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                                                        <TextBox Text="{Binding IntervalMs, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource BlockTextBox}" Width="50"
                                                                 FontSize="11" Padding="4,2"/>
                                                    </DockPanel>
                                                    <DockPanel>
                                                        <TextBlock Text="모드:" Foreground="#888" FontSize="11"
                                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                        <ComboBox SelectedItem="{Binding Mode}" Width="80"
                                                                  FontSize="11" Background="#2d2d44"
                                                                  Foreground="White" BorderBrush="#3f3f5e"
                                                                  Padding="4,3">
                                                            <ComboBox.Resources>
                                                                <Style TargetType="ComboBoxItem">
                                                                    <Setter Property="Foreground" Value="#e0e0e0"/>
                                                                    <Setter Property="Background" Value="#2d2d44"/>
                                                                    <Setter Property="Padding" Value="6,4"/>
                                                                    <Setter Property="FontSize" Value="12"/>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsHighlighted" Value="True">
                                                                            <Setter Property="Background" Value="#5B21B6"/>
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ComboBox.Resources>
                                                            <ComboBoxItem Content="Toggle" IsSelected="True"/>
                                                            <ComboBoxItem Content="Increment"/>
                                                            <ComboBoxItem Content="Fixed"/>
                                                            <ComboBoxItem Content="Monitor"/>
                                                        </ComboBox>
                                                    </DockPanel>
                                                    <!-- Monitor 모드 추가 설정 -->
                                                    <DockPanel Margin="0,4,0,0">
                                                        <TextBlock Text="T/O(ms):" Foreground="#888" FontSize="11"
                                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                        <TextBox Text="{Binding TimeoutMs, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource BlockTextBox}" Width="50"
                                                                 FontSize="11" Padding="4,2"/>
                                                        <TextBlock Text="상태키:" Foreground="#888" FontSize="11"
                                                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                                                        <TextBox Text="{Binding StatusKey, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource BlockTextBox}"
                                                                 FontSize="11" Padding="4,2"
                                                                 ToolTip="빈값이면 자동 생성 (예: D10_alive)"/>
                                                    </DockPanel>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="&#x2716;" FontSize="12"
                                                        Foreground="#666" Background="Transparent"
                                                        BorderThickness="0" Cursor="Hand" VerticalAlignment="Top"
                                                        Command="{Binding DataContext.PeriodicTasks.RemoveTaskCommand,
                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- External Input Simulation -->
                    <Border Grid.Row="2" BorderBrush="#2a2a4a" BorderThickness="0,1,0,0"
                            Padding="16,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="&#x1F4E1;" FontSize="14" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="외부 입력 모사" FontSize="14" Foreground="White"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="시뮬레이터가 '신호 수신 대기' 상태일 때 외부 시스템이 보내는 응답을 여기서 수동으로 전송할 수 있습니다."
                                       Foreground="#777799" FontSize="11" TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>

                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="전송" Background="#5B21B6"
                                        Foreground="White" Padding="16,6" Margin="8,0,0,0"
                                        FontWeight="SemiBold" FontSize="13" Cursor="Hand"
                                        Command="{Binding SendSignalCommand}"
                                        BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <TextBox Text="{Binding SignalInputText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource DarkTextBox}"
                                         x:Name="SignalInput"
                                         KeyDown="SignalInput_KeyDown"/>
                            </DockPanel>
                            <TextBlock Text="예: REQ_01" Foreground="#555577" FontSize="10"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- === Bottom: Execution Log === -->
        <Border Grid.Row="3" Background="#12122a" BorderBrush="#2a2a4a" BorderThickness="0,1,0,0"
                DataContext="{Binding SelectedGroup}">
            <Expander IsExpanded="True" Foreground="White">
                <Expander.Header>
                    <DockPanel Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Expander}}">
                        <TextBlock Text="&#x276F; 실행 로그" FontSize="13" Foreground="#aaaacc"
                                   VerticalAlignment="Center" Margin="0,0,0,0"/>
                        <Button DockPanel.Dock="Right" Content="로그 지우기" Background="Transparent"
                                Foreground="#777799" FontSize="11" Cursor="Hand" BorderThickness="0"
                                HorizontalAlignment="Right" Margin="0,0,20,0"
                                Command="{Binding ExecutionLog.ClearLogCommand}"/>
                    </DockPanel>
                </Expander.Header>
                <ListBox ItemsSource="{Binding ExecutionLog.LogEntries}"
                         Background="Transparent" Foreground="#aaaacc" FontSize="12"
                         FontFamily="Consolas" BorderThickness="0" MaxHeight="200"
                         x:Name="LogListBox"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,2"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#aaaacc"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Expander>
        </Border>
    </Grid>
</Window>
