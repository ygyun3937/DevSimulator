<Window x:Class="TestClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SLMP Test Client" Height="520" Width="480"
        Background="#1e1e1e">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2d2d30"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#3f3f46"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="12">
        <!-- Connection -->
        <Border DockPanel.Dock="Top" Background="#252526" CornerRadius="4"
                Padding="12,10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="연결 설정" FontWeight="Bold" Foreground="#569cd6" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="IP:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="TxtIp" Text="127.0.0.1" Width="120"/>
                    <TextBlock Text="Port:" VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <TextBox x:Name="TxtPort" Text="5000" Width="60"/>
                    <Button x:Name="BtnConnect" Click="BtnConnect_Click"
                            Background="#107c10" Margin="12,0,0,0">연결</Button>
                    <Button x:Name="BtnDisconnect" Click="BtnDisconnect_Click"
                            Background="#d83b01" IsEnabled="False">해제</Button>
                </StackPanel>
                <TextBlock x:Name="TxtStatus" Text="● 미연결" Foreground="#888" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Handshake Test -->
        <Border DockPanel.Dock="Top" Background="#252526" CornerRadius="4"
                Padding="12,10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="핸드쉐이크 테스트" FontWeight="Bold" Foreground="#569cd6" Margin="0,0,0,6"/>
                <TextBlock Text="시나리오: M100=1 요청 → M101 완료 대기 → 결과 읽기 → M100=0 리셋"
                           FontSize="10" Foreground="#888" TextWrapping="Wrap" Margin="0,0,0,8"/>
                <Button x:Name="BtnHandshake" Click="BtnHandshake_Click"
                        Background="#0078d4" IsEnabled="False"
                        HorizontalAlignment="Left">▶ 핸드쉐이크 실행</Button>
            </StackPanel>
        </Border>

        <!-- Manual R/W -->
        <Border DockPanel.Dock="Top" Background="#252526" CornerRadius="4"
                Padding="12,10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="수동 읽기/쓰기" FontWeight="Bold" Foreground="#569cd6" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="디바이스:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="TxtDevice" Text="D200" Width="80"/>
                    <Button x:Name="BtnRead" Click="BtnRead_Click"
                            Background="#0e639c" IsEnabled="False">읽기</Button>
                    <TextBlock Text="값:" VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <TextBox x:Name="TxtValue" Text="0" Width="60"/>
                    <Button x:Name="BtnWrite" Click="BtnWrite_Click"
                            Background="#ca5010" IsEnabled="False">쓰기</Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Log -->
        <Border Background="#252526" CornerRadius="4" Padding="12,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="로그" FontWeight="Bold"
                           Foreground="#569cd6" Margin="0,0,0,6"/>
                <ListBox x:Name="LogList" Background="#1e1e1e" Foreground="#e0e0e0"
                         BorderThickness="0" FontSize="11" FontFamily="Consolas"/>
            </DockPanel>
        </Border>
    </DockPanel>
</Window>
